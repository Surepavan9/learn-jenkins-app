pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    
                    # Downgrade npm to a stable version
                    npm install -g npm@9.8.1
                    
                    npm --version
                    npm ci
                    npm run build
                    ls -la
                '''
            }
        }
        stage('Test') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    # Downgrade npm
                    npm install -g npm@9.8.1
                    
                    # Test if build directory exists
                    test -d build && echo "Build directory exists" || exit 1
                    
                    # Test if index.html is present in build
                    test -f build/index.html && echo "index.html exists" || exit 1

                    # Run npm tests
                    npm test -- --watchAll=false
                '''
            }
        }
    }
}