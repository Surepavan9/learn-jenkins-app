pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    npm cache clean --force
                    rm -rf node_modules
                    npm install --legacy-peer-deps
                    npm run build
                    ls -la
                '''
            }
        }
    }
}