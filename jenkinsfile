pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    
                    # Skip npm ci and use existing node_modules
                    # npm config set strict-ssl false
                    # npm ci
                    
                    npm run build
                    ls -la
                '''
            }
        }
        stage('Test') {
            agent {
                docker {
                    image 'node:20'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    # Test if build directory exists
                    test -d build && echo "Build directory exists" || exit 1
                    
                    # Test if index.html is present in build
                    test -f build/index.html && echo "index.html exists" || exit 1

                    # Run npm tests
                    npm test -- --watchAll=false
                '''
            }
        }
    }
}